generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Token {
  id              String   @id @default(cuid())
  mint            String   @unique
  name            String
  symbol          String
  description     String?
  imageUrl        String?
  websiteUrl      String?
  twitterUrl      String?
  telegramUrl     String?
  creator         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Curve state (cached from on-chain)
  virtualSolReserves    BigInt @default(30000000000)
  virtualTokenReserves  BigInt @default(1073000191000000)
  realSolReserves       BigInt @default(0)
  realTokenReserves     BigInt @default(700000000000000)
  totalSupply           BigInt @default(1000000000000000)

  // Stats
  marketCapSol    Float    @default(0)
  priceUsd        Float    @default(0)
  volume24h       Float    @default(0)
  trades          Int      @default(0)
  holders         Int      @default(0)
  isGraduated     Boolean  @default(false)
  graduatedAt     DateTime?
  raydiumPoolId   String?

  // Relations
  tradeHistory    Trade[]
  comments        Comment[]

  @@index([creator])
  @@index([isGraduated])
  @@index([marketCapSol])
  @@index([createdAt])
  @@index([volume24h])
}

model Trade {
  id          String    @id @default(cuid())
  signature   String    @unique
  mint        String
  trader      String
  type        TradeType
  solAmount   BigInt
  tokenAmount BigInt
  price       Float
  fee         BigInt
  timestamp   DateTime
  createdAt   DateTime  @default(now())

  token       Token     @relation(fields: [mint], references: [mint])

  @@index([mint])
  @@index([trader])
  @@index([timestamp])
}

enum TradeType {
  BUY
  SELL
}

model Comment {
  id        String   @id @default(cuid())
  mint      String
  wallet    String
  text      String   @db.VarChar(280)
  createdAt DateTime @default(now())

  token     Token    @relation(fields: [mint], references: [mint], onDelete: Cascade)

  @@index([mint])
  @@index([createdAt])
}

// Per-mint holder balances — maintained by the indexer on every buy/sell.
// Replaces the expensive "SELECT … GROUP BY trader" fallback and the
// multi-round-trip RPC path in GET /tokens/:mint/holders.
model Holder {
  id        Int      @id @default(autoincrement())
  mint      String
  wallet    String
  balance   BigInt   @default(0)
  updatedAt DateTime @updatedAt

  @@unique([mint, wallet])
  @@index([mint, balance])
}

// Social follow graph — wallet-to-wallet, no auth required (wallet IS identity)
model Follow {
  id          String   @id @default(cuid())
  follower    String   // wallet that is following
  following   String   // wallet being followed (creator)
  createdAt   DateTime @default(now())

  @@unique([follower, following])
  @@index([follower])
  @@index([following])
}
