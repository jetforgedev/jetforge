# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tokendex"

# Solana
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_WS_URL="wss://api.devnet.solana.com"
PROGRAM_ID="TokenLaunchXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TREASURY_ADDRESS="TreasuryXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Server
PORT=4000
FRONTEND_URL="http://localhost:3000"

# Treasury keypair for automatic Raydium pool creation on graduation.
# Format: JSON array from `solana-keygen` (e.g. contents of your keypair .json)
# Example: [12,34,56,...] — leave empty to disable auto pool creation (graduation
# will still trigger on-chain but the Raydium pool must be created manually).
# ⚠️  NEVER commit this value. backend/.env is in .gitignore.
TREASURY_PRIVATE_KEY=""

# Optional: CoinGecko for SOL price
COINGECKO_API_KEY=""
