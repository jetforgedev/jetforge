datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres@localhost:5432/tokendex"
}

model Token {
  id                   String    @id
  mint                 String    @unique
  name                 String
  symbol               String
  description          String?
  imageUrl             String?
  websiteUrl           String?
  twitterUrl           String?
  telegramUrl          String?
  creator              String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  virtualSolReserves   BigInt    @default(30000000000)
  virtualTokenReserves BigInt    @default(1073000191000000)
  realSolReserves      BigInt    @default(0)
  realTokenReserves    BigInt    @default(1000000000000000)
  totalSupply          BigInt    @default(1000000000000000)
  marketCapSol         Float     @default(0)
  priceUsd             Float     @default(0)
  volume24h            Float     @default(0)
  trades               Int       @default(0)
  holders              Int       @default(0)
  isGraduated          Boolean   @default(false)
  graduatedAt          DateTime?
  Trade                Trade[]

  @@index([createdAt])
  @@index([creator])
  @@index([isGraduated])
  @@index([marketCapSol])
  @@index([volume24h])
}

model Trade {
  id          String    @id
  signature   String    @unique
  mint        String
  trader      String
  type        TradeType
  solAmount   BigInt
  tokenAmount BigInt
  price       Float
  fee         BigInt
  timestamp   DateTime
  createdAt   DateTime  @default(now())
  Token       Token     @relation(fields: [mint], references: [mint])

  @@index([mint])
  @@index([timestamp])
  @@index([trader])
}

enum TradeType {
  BUY
  SELL
}
